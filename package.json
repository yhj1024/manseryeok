{
  "name": "manseryeok",
  "version": "2.0.0",
  "description": "Korean Saju (Four Pillars) and Manseryeok calculation library with true solar time correction",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "saju",
    "manseryeok",
    "korean",
    "fortune-telling",
    "bazi",
    "four-pillars",
    "true-solar-time",
    "사주",
    "만세력",
    "진태양시"
  ],
  "author": "Yoohyojun <hyojun99222@gmail.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.33.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/yhj1024/manseryeok"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "prepublishOnly": "pnpm lint && pnpm test:run && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@types/node": "^24.0.13",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "lunar-javascript": "^1.7.7",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
